{
  "name": "insightiq",
  "version": "1.0.0",
  "description": "InsightIQ - AI-Powered Business Analytics Platform",
  "main": "server/server.js",
  "scripts": {
    "build": "cd client && npm ci && npm run build",
    "start": "node server/server.js",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "install-deps": "cd server && npm install && cd ../client && npm install"
  },
  "keywords": [
    "analytics",
    "ai",
    "business",
    "insights",
    "react",
    "nodejs"
  ],
  "author": "InsightIQ Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "csv-parser": "^3.0.0",
    "xlsx": "^0.18.5",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
