# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insightiq
DB_USER=amrutha
DB_PASSWORD=your_actual_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_1234567890abcdef
JWT_EXPIRES_IN=7d

# AI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
# OR
GROQ_API_KEY=your_groq_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Production Environment Variables
# Replace these with actual production values when deploying
# DATABASE_URL=postgresql://username:password@host:port/database
# JWT_SECRET=your_production_jwt_secret_minimum_32_characters_long
# OPENAI_API_KEY=sk-your-actual-openai-api-key
# GROQ_API_KEY=gsk_your-actual-groq-api-key
# FRONTEND_URL=https://your-production-domain.com
